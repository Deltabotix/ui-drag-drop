{
  "name": "deltabot-studio-frontend",
  "version": "1.0.0",
  "description": "DeltaBot Studio frontend - Enterprise visual programming platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "postinstall": "patch-package",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
